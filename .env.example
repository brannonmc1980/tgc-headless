# ─── WordPress Backend Configuration ───────────────────────────────────────
# Set this to your WordPress installation URL.
# Example: https://cms.yourdomain.com
WORDPRESS_API_URL=

# Set to "true" to use built-in mock data (no WordPress needed for development)
USE_MOCK_DATA=true

# ─── Site Configuration ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app
NEXT_PUBLIC_SITE_NAME=The Gospel Coalition

# ─── Optional: WordPress Application Password ────────────────────────────────
# Used for authenticated API calls (draft previews, etc.)
# Format: username:app-password
WP_AUTH=

# ─── Optional: Analytics ────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
